# Copy to `.env` and fill in. NEVER commit the real .env (see .gitignore).
#
# api.sec-api.io API key. Required by tools/sec_downloader.py.
# Obtain from https://sec-api.io/ (paid; queries are metered).
SEC_API_KEY=

# Optional: cap the number of paid query/download calls a single run may make.
# tools/sec_downloader.py refuses to exceed this without an explicit override.
# Set to 0 to disable the guard (NOT recommended).
SEC_API_BUDGET_CALLS=250

# Optional: contact string sent in the User-Agent header (good API hygiene).
SEC_API_USER_AGENT=Coremont Clarion Prospecting (malex.clark@gmail.com)
