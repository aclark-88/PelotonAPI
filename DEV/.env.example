# Copy to `.env` and fill in. NEVER commit the real .env (see .gitignore).
#
# SEC fair-access identity. EDGAR requires a descriptive User-Agent of the form
# "Name email@example.com" on every request. edgartools reads this. Required.
EDGAR_IDENTITY=Coremont Clarion Prospecting malex.clark@gmail.com

# Optional: cap how many filings a single query may pull, so a wide date range
# cannot trigger a runaway batch. EDGAR is free, but this honors the
# "no high-volume run without verification" safety rule. Default: 500.
EDGAR_MAX_FILINGS=500
