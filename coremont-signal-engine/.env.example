# Coremont Signal Engine configuration
#
# Production: point at Postgres.
#   DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/coremont
#
# Dev / test: leave DATABASE_URL unset to use a local SQLite file (coremont.db).
DATABASE_URL=

# SEC EDGAR requires a descriptive User-Agent that includes a contact email.
# https://www.sec.gov/os/webmaster-faq#developers
SEC_USER_AGENT=Coremont Signal Engine (ops@coremont.example.com)

# How many days back the daily ingestion job scans on each run.
INGEST_LOOKBACK_DAYS=7

# Optional HubSpot private-app token for CRM sync (Job 5). If unset, export
# falls back to CSV only.
HUBSPOT_TOKEN=
